# CLAUX — variables de entorno
# Copia este archivo a .env.local y rellena los valores reales.
# .env.local NUNCA se commitea (está en .gitignore).
#
# AVISO: en local la app se conecta a la Supabase COMPARTIDA en la nube.
#        Los datos NO son locales: cualquier cambio afecta al entorno compartido.

# ── Supabase (obligatorias) ─────────────────────────────────────────────
# Dashboard de Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=REEMPLAZAR_anon_key
# service_role bypassa RLS — solo se usa en servidor (src/lib/supabase/admin.ts). NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=REEMPLAZAR_service_role_key

# ── Sesión del portal (obligatoria) ─────────────────────────────────────
# Secreto para firmar el JWT HMAC del portal de clientes. Genera uno con: openssl rand -hex 32
PORTAL_JWT_SECRET=REEMPLAZAR_secreto_largo_aleatorio

# ── Tasas de cambio elToque (opcional) ──────────────────────────────────
# Sin esta clave, la pantalla de Monedas degrada (no rompe la app).
ELTOQUE_API_KEY=

# ── Resend (correos transaccionales, obligatoria para notificaciones) ──
# Dashboard de Resend → API Keys. Dominio remitente: claux.es (verificado).
RESEND_API_KEY=

# ── Cron de recordatorios (Fase 2 de correos) ───────────────────────────
# Secreto que protege /api/cron/recordatorios. Vercel Cron manda automáticamente
# `Authorization: Bearer <CRON_SECRET>` si esta env var existe en el proyecto.
# Genera uno con: openssl rand -hex 32. Para probar en local: curl con ese header.
CRON_SECRET=

# ── Desarrollo local: bypass de login (SOLO dev) ────────────────────────
# DOBLE CANDADO: el bypass solo se activa si NODE_ENV=development (lo fija `next dev`)
# Y esta variable está en 'true'. En `next build`/`next start` NODE_ENV=production,
# así que queda INERTE aunque la dejes en true. Mantener en false salvo desarrollo.
DEV_BYPASS_AUTH=false
# Para capar también el login del PORTAL, impersona un tenant REAL de la Supabase
# compartida (déjalo vacío para capar solo el admin):
DEV_PORTAL_CLIENT_ID=
DEV_PORTAL_USER_ID=
DEV_PORTAL_ROL=admin_empresa
DEV_PORTAL_EMAIL=dev@local
